{
  "name": "client-mgmt-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create client-mgmt-db",
    "db:migrate": "wrangler d1 execute client-mgmt-db --file=migrations/001_init.sql",
    "db:migrate:prod": "wrangler d1 execute client-mgmt-db --remote --file=migrations/001_init.sql"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
